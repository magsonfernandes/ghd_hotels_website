{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter @caffeine/template-frontend build",
  "outputDirectory": "src/frontend/dist",
  "rewrites": [
    { "source": "/contact-submit", "destination": "/api/contact" },
    { "source": "/careers-apply", "destination": "/api/careers" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
